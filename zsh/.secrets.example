# ~/.secrets.local - Machine-specific secrets (DO NOT COMMIT)
# Copy this to ~/.secrets.local and fill in values

# RPC Providers
export ALCHEMY_API_KEY=""
export WORLDCHAIN_PROVIDER="https://worldchain-mainnet.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export ETHEREUM_PROVIDER="https://eth-mainnet.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export ETHEREUM_WS_PROVIDER="wss://eth-mainnet.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export OPTIMISM_PROVIDER="https://opt-mainnet.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export ETHEREUM_SEPOLIA_PROVIDER="https://eth-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export WORLDCHAIN_SEPOLIA_PROVIDER="https://worldchain-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export OPTIMISM_SEPOLIA_PROVIDER="https://opt-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY"

# Auth tokens
export GITHUB_TOKEN=""
export JWT_PROD=""

